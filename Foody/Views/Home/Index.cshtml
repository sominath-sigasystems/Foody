@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to AuthMvcApp</h1>
    <p class="lead">A secure authentication system built with ASP.NET Core 8 MVC</p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <p>You are logged in as <strong>@User.Identity?.Name</strong></p>
        <a asp-controller="Account" asp-action="Profile" class="btn btn-primary">View Profile</a>
    }
    else
    {
        <p>Please <a asp-controller="Account" asp-action="Login">login</a> or <a asp-controller="Account" asp-action="Register">register</a> to continue.</p>
    }
</div>