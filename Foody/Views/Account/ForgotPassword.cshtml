@model Foody.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 animate-fade-in">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
                        </div>
                        <h2 class="fw-bold text-primary">@ViewData["Title"]</h2>
                        <p class="text-muted">Enter your email and we'll send you a reset link</p>
                    </div>

                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                        <!-- Email -->
                        <div class="form-floating mb-4">
                            <input asp-for="Email" class="form-control form-control-lg" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Email" class="form-label"></label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Submit Button -->
                        <button id="forgotPasswordSubmit" type="submit" class="w-100 btn btn-primary btn-lg mb-4 shadow-sm">
                            <span id="btnText"><i class="bi bi-envelope"></i> Send Reset Link</span>
                            <span id="btnLoader" class="d-none">
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Sending...
                            </span>
                        </button>
                    </form>

                    <!-- Back to Login -->
                    <div class="text-center">
                        <a asp-action="Login" class="text-primary text-decoration-none fw-bold">
                            <i class="bi bi-arrow-left"></i> Back to Login
                        </a>
                    </div>

                    <!-- Info Box -->
                    <div class="mt-4 p-3 bg-light rounded-3">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> If an account exists with this email, you'll receive a password reset link shortly.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
        .animate-fade-in {
            animation: fadeIn 0.5s ease-in-out;
        }
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
            transition: all 0.3s ease;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            const submitBtn = document.getElementById('forgotPasswordSubmit');
            const btnText = document.getElementById('btnText');
            const btnLoader = document.getElementById('btnLoader');

            if (form && submitBtn) {
                form.addEventListener('submit', function(e) {
                    if (form.checkValidity()) {
                        btnText.classList.add('d-none');
                        btnLoader.classList.remove('d-none');
                        submitBtn.disabled = true;
                    }
                });
            }

            // Auto-focus email
            const emailInput = document.querySelector('input[autocomplete="username"]');
            if (emailInput) {
                setTimeout(() => emailInput.focus(), 300);
            }
        });
    </script>
}