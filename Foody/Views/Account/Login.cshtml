@model Foody.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log in";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 animate-fade-in">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">@ViewData["Title"]</h2>
                        <p class="text-muted">Welcome back! Please sign in to continue</p>
                    </div>

                    <form id="account" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                        <!-- Email -->
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control form-control-lg" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Email" class="form-label"></label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Password with Toggle -->
                        <div class="mb-3">
                            <div class="form-floating position-relative">
                                <input asp-for="Password" class="form-control form-control-lg" id="passwordInput" autocomplete="current-password" placeholder="Password" />
                                <label asp-for="Password" class="form-label"></label>
                                <button type="button" class="btn btn-link position-absolute end-0 top-0 p-0 me-3 mt-2" id="togglePassword" style="z-index: 10;">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="RememberMe" id="rememberMe">
                                <label class="form-check-label" for="rememberMe">
                                    @Html.DisplayNameFor(m => m.RememberMe)
                                </label>
                            </div>
                            <a asp-action="ForgotPassword" class="text-primary text-decoration-none fw-bold" style="font-size: 0.9rem;">
                                Forgot Password?
                            </a>
                        </div>

                        <!-- Submit Button with Loading State -->
                        <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg mb-4 shadow-sm">
                            <span id="btnText"><i class="bi bi-box-arrow-in-right"></i> Log in</span>
                            <span id="btnLoader" class="d-none">
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Signing in...
                            </span>
                        </button>
                    </form>

                    <!-- Divider -->
                    <div class="text-center mb-4">
                        <hr class="text-muted" />
                        <small class="text-muted">Don't have an account?</small>
                    </div>

                    <!-- Register Link -->
                    <div class="text-center">
                        <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="btn btn-outline-primary btn-lg w-100">
                            <i class="bi bi-person-plus"></i> Create New Account
                        </a>
                    </div>

                    <!-- Quick Role Info -->
                    <div class="mt-4 p-3 bg-light rounded-3">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            <strong>Quick Info:</strong><br>
                            🍕 <strong>Foodie?</strong> Order from your favorite restaurants<br>
                            🏪 <strong>Owner?</strong> Manage your restaurant dashboard<br>
                            🚴 <strong>Delivery?</strong> Track and deliver orders
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
        /* ✅ Smooth Fade In Animation */
        .animate-fade-in {
            animation: fadeIn 0.5s ease-in-out;
        }
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* ✅ Password Toggle Button */
        #togglePassword {
            background: none;
            border: none;
            color: #6c757d;
            cursor: pointer;
            transition: color 0.3s ease;
        }

            #togglePassword:hover {
                color: #0d6efd;
            }

        /* ✅ Form Focus Effects */
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }

        /* ✅ Remember Me Checkbox Styling */
        .form-check-input:checked {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        /* ✅ Button Hover Effects */
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
            transition: all 0.3s ease;
        }

        .btn-outline-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2);
            transition: all 0.3s ease;
        }

        /* ✅ Card Hover Effect */
        .card {
            transition: box-shadow 0.3s ease;
        }

            .card:hover {
                box-shadow: 0 10px 40px rgba(0,0,0,0.15) !important;
            }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ✅ 1. Password Visibility Toggle
            const passwordInput = document.getElementById('passwordInput');
            const togglePassword = document.getElementById('togglePassword');
            const icon = togglePassword.querySelector('i');

            if (togglePassword && passwordInput) {
                togglePassword.addEventListener('click', function() {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);

                    // Toggle icon
                    icon.classList.toggle('bi-eye');
                    icon.classList.toggle('bi-eye-slash');

                    // Add visual feedback
                    togglePassword.style.color = type === 'text' ? '#0d6efd' : '#6c757d';
                });
            }

            // ✅ 2. Form Submit Loading State
            const form = document.getElementById('account');
            const submitBtn = document.getElementById('login-submit');
            const btnText = document.getElementById('btnText');
            const btnLoader = document.getElementById('btnLoader');

            if (form && submitBtn) {
                form.addEventListener('submit', function(e) {
                    // Only show loader if form is valid (basic check)
                    if (form.checkValidity()) {
                        btnText.classList.add('d-none');
                        btnLoader.classList.remove('d-none');
                        submitBtn.disabled = true;

                        // Optional: Add animation to button
                        submitBtn.style.opacity = '0.8';
                    }
                });
            }

            // ✅ 3. Input Field Animation on Focus
            const inputs = document.querySelectorAll('.form-control');
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.parentElement.classList.add('focused');
                });
                input.addEventListener('blur', function() {
                    this.parentElement.classList.remove('focused');
                });
            });

            // ✅ 4. Auto-focus on Email field for better UX
            const emailInput = document.querySelector('input[autocomplete="username"]');
            if (emailInput) {
                setTimeout(() => {
                    emailInput.focus();
                }, 300);
            }
        });
    </script>
}