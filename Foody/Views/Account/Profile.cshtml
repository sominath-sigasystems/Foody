@model Foody.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    var roles = ViewBag.UserRoles as System.Collections.Generic.IList<string> ?? new List<string>();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <!-- Profile Header Card -->
            <div class="card shadow-lg border-0 rounded-4 mb-4 animate-fade-in">
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-white rounded-circle p-3 me-3">
                            <i class="bi bi-person-circle text-primary" style="font-size: 3rem;"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold mb-0">@Model?.FullName</h2>
                            <p class="mb-0 opacity-75">@Model?.Email</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <!-- Role Badges -->
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted">Account Type</label>
                        <div class="d-flex gap-2">
                            @foreach (var role in roles)
                            {
                                var badgeClass = role switch
                                {
                                    "User" => "bg-primary",
                                    "RestaurantOwner" => "bg-success",
                                    "DeliveryBoy" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                <span class="badge @badgeClass px-3 py-2" style="font-size: 0.9rem;">
                                    <i class="bi bi-patch-check"></i> @role
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Profile Details Grid -->
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-envelope text-primary me-2"></i>
                                    <small class="text-muted">Email Address</small>
                                </div>
                                <p class="fw-bold mb-0">@Model?.Email</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-telephone text-primary me-2"></i>
                                    <small class="text-muted">Phone Number</small>
                                </div>
                                <p class="fw-bold mb-0">@(!string.IsNullOrEmpty(Model?.PhoneNumber) ? Model.PhoneNumber : "Not provided")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-calendar-check text-primary me-2"></i>
                                    <small class="text-muted">Account Created</small>
                                </div>
                                <p class="fw-bold mb-0">@Model?.CreatedAt?.ToString("MMMM dd, yyyy")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-shield-check text-primary me-2"></i>
                                    <small class="text-muted">Email Verified</small>
                                </div>
                                <p class="fw-bold mb-0">
                                    @if (Model?.EmailConfirmed == true)
                                    {
                                        <span class="text-success"><i class="bi bi-check-circle"></i> Yes</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning"><i class="bi bi-exclamation-circle"></i> No</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex gap-2 mt-4 pt-4 border-top">
                        <a asp-action="EditProfile" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Edit Profile
                        </a>
                        <a asp-action="ChangePassword" class="btn btn-outline-secondary">
                            <i class="bi bi-key"></i> Change Password
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Card (Role-Specific) -->
            @if (roles.Contains("User"))
            {
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-cart3"></i> Your Orders</h5>
                        <div class="row g-3">
                            <div class="col-4 text-center">
                                <div class="display-6 text-primary fw-bold">0</div>
                                <small class="text-muted">Total Orders</small>
                            </div>
                            <div class="col-4 text-center">
                                <div class="display-6 text-success fw-bold">0</div>
                                <small class="text-muted">Completed</small>
                            </div>
                            <div class="col-4 text-center">
                                <div class="display-6 text-warning fw-bold">0</div>
                                <small class="text-muted">Pending</small>
                            </div>
                        </div>
                        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-primary mt-3">
                            View All Orders
                        </a>
                    </div>
                </div>
            }

            @if (roles.Contains("RestaurantOwner"))
            {
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-shop"></i> Restaurant Dashboard</h5>
                        <div class="d-grid gap-2">
                            <a asp-controller="Restaurant" asp-action="Dashboard" class="btn btn-success">
                                <i class="bi bi-speedometer2"></i> Go to Dashboard
                            </a>
                            <a asp-controller="Menu" asp-action="Manage" class="btn btn-outline-success">
                                <i class="bi bi-menu-button"></i> Manage Menu
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (roles.Contains("DeliveryBoy"))
            {
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-bicycle"></i> Delivery Dashboard</h5>
                        <div class="d-grid gap-2">
                            <a asp-controller="Delivery" asp-action="PendingOrders" class="btn btn-warning">
                                <i class="bi bi-clipboard-data"></i> Pending Deliveries
                            </a>
                            <a asp-controller="Delivery" asp-action="DeliveryHistory" class="btn btn-outline-warning">
                                <i class="bi bi-clock-history"></i> Delivery History
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .animate-fade-in {
            animation: fadeIn 0.5s ease-in-out;
        }
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .card:hover {
            box-shadow: 0 10px 40px rgba(0,0,0,0.15) !important;
            transition: box-shadow 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-2px);
            transition: all 0.3s ease;
        }
    </style>
}