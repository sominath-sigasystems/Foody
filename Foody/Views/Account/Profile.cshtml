@model Foody.Models.ApplicationUser
@{
    ViewData["Title"] = "User Profile";
}

<h2>@ViewData["Title"]</h2>
<div class="card">
    <div class="card-body">
        <h5 class="card-title">User Information</h5>
        <p><strong>Full Name:</strong> @Model?.FullName</p>
        <p><strong>Email:</strong> @Model?.Email</p>
        <p><strong>Phone:</strong> @Model?.PhoneNumber</p>
        <p><strong>Account Created:</strong> @Model?.CreatedAt?.ToString("MMMM dd, yyyy")</p>
        <p><strong>Email Confirmed:</strong> @(Model?.EmailConfirmed == true ? "Yes" : "No")</p>
    </div>
</div>